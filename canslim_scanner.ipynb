   "source": [
    "# 📈 CAN SLIM Stock Scanner\n",
    "**Based on William O'Neil's *How to Make Money in Stocks***\n",
    "\n",
    "---\n",
    "\n",
    "| Letter | Criteria | Threshold |\n",
    "|--------|----------|-----------|\n",
    "| **C** | Current quarterly EPS growth YoY | ≥ 25% |\n",
    "| **A** | Annual EPS growth (3-yr avg) | ≥ 25% |\n",
    "| **N** | Near 52-week high | Within 10% |\n",
    "| **S** | Up/Down volume ratio (accumulation) | ≥ 1.0 |\n",
    "| **L** | Relative Strength vs S&P 500 | RS ≥ 70/99 |\n",
    "| **I** | Industry / Institutional ownership | Informational |\n",
    "| **M** | Market direction (SPY above 50-day MA) | Must pass |\n",
    "\n",
    "---\n",
    "\n",
    "### How to use\n",
    "1. **Run Setup** (Cell 1) — installs dependencies\n",
    "2. **Configure** (Cell 2) — paste your watchlist, tweak thresholds\n",
    "3. **Scan** (Cell 3) — runs all 7 criteria\n",
    "4. **Review** (Cell 4+) — view results, charts, export CSV"
   ],
   "id": "intro-md"
  },
  {
   "cell_type": "code",
   "execution_count": null,
   "metadata": {},
   "outputs": [],
   "source": [
    "# ─────────────────────────────────────────────────────────────\n",
    "# CELL 1 — Setup: Install dependencies & import module\n",
    "# ─────────────────────────────────────────────────────────────\n",
    "import subprocess, sys\n",
    "\n",
    "# Install required packages\n",
    "subprocess.run([sys.executable, '-m', 'pip', 'install', '-q',\n",
    "                'yfinance', 'pandas', 'numpy', 'matplotlib', 'seaborn'])\n",
    "\n",
    "# If running in Colab, clone/upload canslim_scanner.py first\n",
    "# OR paste the module inline via the next cell\n",
    "print('✓ Dependencies ready')"
   ],
   "id": "cell-setup"
  },
  {
   "cell_type": "code",
   "execution_count": null,
   "metadata": {},
   "outputs": [],
   "source": [
    "# ─────────────────────────────────────────────────────────────\n",
    "# CELL 1b — Load the scanner module\n",
    "#\n",
    "# Option A (Colab): Upload canslim_scanner.py via Files panel,\n",
    "#   then this import will work automatically.\n",
    "#\n",
    "# Option B (GitHub): Uncomment the wget line below.\n",
    "# ─────────────────────────────────────────────────────────────\n",
    "\n",
    "# Option B — pull directly from your GitHub repo:\n",
    "# !wget -q https://raw.githubusercontent.com/YOUR_USERNAME/canslim_scanner/main/canslim_scanner.py\n",
    "\n",
    "from canslim_scanner import CANSLIMScanner, WATCHLISTS, CONFIG\n",
    "\n",
    "print('✓ CANSLIMScanner loaded')\n",
    "print(f'  Available watchlists: {list(WATCHLISTS.keys())}')"
   ],
   "id": "cell-import"
  },
  {
   "cell_type": "code",
   "execution_count": null,
   "metadata": {},
   "outputs": [],
   "source": [
    "# ─────────────────────────────────────────────────────────────\n",
    "# CELL 2 — Configure your scan\n",
    "# ─────────────────────────────────────────────────────────────\n",
    "\n",
    "# ── Your custom watchlist ──────────────────────────────────\n",
    "MY_WATCHLIST = [\n",
    "    \"NVDA\", \"AAPL\", \"MSFT\", \"GOOGL\", \"META\",\n",
    "    \"JPM\",  \"GS\",   \"V\",    \"MA\",\n",
    "    \"UNH\",  \"LLY\",\n",
    "    \"CAT\",  \"DE\",\n",
    "]\n",
    "# Or use a preset:\n",
    "# MY_WATCHLIST = WATCHLISTS['mega_cap_tech']\n",
    "# MY_WATCHLIST = WATCHLISTS['financials']\n",
    "\n",
    "# ── Threshold overrides (optional) ────────────────────────\n",
    "MY_CONFIG = {\n",
    "    # Uncomment to override defaults:\n",
    "    # 'C_min_eps_growth':        20.0,   # lower bar for EPS growth\n",
    "    # 'L_min_rs_rating':         60.0,   # accept slightly weaker RS\n",
    "    # 'N_near_high_pct':         15.0,   # allow 15% below 52-wk high\n",
    "}\n",
    "\n",
    "# ── Minimum criteria to appear in results ─────────────────\n",
    "MIN_PASSES = 4   # out of 7\n",
    "\n",
    "print(f'✓ Watchlist set: {len(MY_WATCHLIST)} symbols')\n",
    "print(f'  Symbols: {MY_WATCHLIST}')\n",
    "print(f'  Min passes: {MIN_PASSES}/7')"
   ],
   "id": "cell-config"
  },
  {
   "cell_type": "code",
   "execution_count": null,
   "metadata": {},
   "outputs": [],
   "source": [
    "# ─────────────────────────────────────────────────────────────\n",
    "# CELL 3 — Run the scan\n",
    "# ─────────────────────────────────────────────────────────────\n",
    "\n",
    "scanner = CANSLIMScanner(config=MY_CONFIG)\n",
    "results = scanner.scan(MY_WATCHLIST, min_passes=MIN_PASSES)\n",
    "\n",
    "scanner.print_results(results)"
   ],
   "id": "cell-scan"
  },
  {
   "cell_type": "code",
   "execution_count": null,
   "metadata": {},
   "outputs": [],
   "source": [
    "# ─────────────────────────────────────────────────────────────\n",
    "# CELL 4 — Results as DataFrame\n",
    "# ─────────────────────────────────────────────────────────────\n",
    "import pandas as pd\n",
    "\n",
    "df = scanner.to_dataframe(results)\n",
    "\n",
    "# Summary view\n",
    "summary_cols = [\"Symbol\", \"Passes\",\n",
    "                \"C_pass\", \"A_pass\", \"N_pass\",\n",
    "                \"S_pass\", \"L_pass\", \"I_pass\", \"M_pass\",\n",
    "                \"L_value\", \"S_value\", \"N_value\"]\n",
    "\n",
    "print(df[summary_cols].to_string(index=False))\n",
    "df"
   ],
   "id": "cell-dataframe"
  },
  {
   "cell_type": "code",
   "execution_count": null,
   "metadata": {},
   "outputs": [],
   "source": [
    "# ─────────────────────────────────────────────────────────────\n",
    "# CELL 5 — Heatmap: CAN SLIM pass/fail grid\n",
    "# ─────────────────────────────────────────────────────────────\n",
    "import matplotlib.pyplot as plt\n",
    "import matplotlib.patches as mpatches\n",
    "import numpy as np\n",
    "\n",
    "criteria = [\"C\", \"A\", \"N\", \"S\", \"L\", \"I\", \"M\"]\n",
    "symbols  = df[\"Symbol\"].tolist()\n",
    "\n",
    "matrix = np.array([\n",
    "    [int(df.loc[df[\"Symbol\"] == sym, f\"{c}_pass\"].values[0])\n",
    "     for c in criteria]\n",
    "    for sym in symbols\n",
    "])\n",
    "\n",
    "fig, ax = plt.subplots(figsize=(10, max(4, len(symbols) * 0.55)))\n",
    "cmap = plt.cm.get_cmap(\"RdYlGn\", 2)\n",
    "im = ax.imshow(matrix, cmap=cmap, aspect=\"auto\", vmin=0, vmax=1)\n",
    "\n",
    "ax.set_xticks(range(len(criteria)))\n",
    "ax.set_xticklabels(criteria, fontsize=13, fontweight='bold')\n",
    "ax.set_yticks(range(len(symbols)))\n",
    "ax.set_yticklabels(symbols, fontsize=11)\n",
    "\n",
    "for i in range(len(symbols)):\n",
    "    for j in range(len(criteria)):\n",
    "        val = matrix[i, j]\n",
    "        ax.text(j, i, \"✓\" if val else \"✗\",\n",
    "                ha=\"center\", va=\"center\",\n",
    "                fontsize=14, color=\"white\" if val else \"#444\")\n",
    "\n",
    "passes = df[\"Passes\"].tolist()\n",
    "for i, (sym, p) in enumerate(zip(symbols, passes)):\n",
    "    ax.text(len(criteria) + 0.3, i, f\"{p}/7\",\n",
    "            va=\"center\", fontsize=10, color=\"#333\")\n",
    "\n",
    "ax.set_title(\"CAN SLIM Scan Results\", fontsize=15, fontweight='bold', pad=12)\n",
    "ax.set_xlabel(\"Criteria\", fontsize=11)\n",
    "patches = [\n",
    "    mpatches.Patch(color=cmap(1), label=\"Pass\"),\n",
    "    mpatches.Patch(color=cmap(0), label=\"Fail\")\n",
    "]\n",
    "ax.legend(handles=patches, loc=\"upper right\", bbox_to_anchor=(1.15, 1.1))\n",
    "\n",
    "plt.tight_layout()\n",
    "plt.savefig(\"canslim_heatmap.png\", dpi=150, bbox_inches='tight')\n",
    "plt.show()\n",
    "print(\"\\n  Saved → canslim_heatmap.png\")"
   ],
   "id": "cell-heatmap"
  },
  {
   "cell_type": "code",
   "execution_count": null,
   "metadata": {},
   "outputs": [],
   "source": [
    "# ─────────────────────────────────────────────────────────────\n",
    "# CELL 6 — RS Rating bar chart (top performers)\n",
    "# ─────────────────────────────────────────────────────────────\n",
    "import matplotlib.pyplot as plt\n",
    "\n",
    "rs_df = df[[\"Symbol\", \"L_value\", \"Passes\"]].dropna(subset=[\"L_value\"])\n",
    "rs_df = rs_df.sort_values(\"L_value\", ascending=True)\n",
    "\n",
    "colors = [\"#2ecc71\" if v >= 70 else \"#e74c3c\" for v in rs_df[\"L_value\"]]\n",
    "\n",
    "fig, ax = plt.subplots(figsize=(9, max(4, len(rs_df) * 0.5)))\n",
    "bars = ax.barh(rs_df[\"Symbol\"], rs_df[\"L_value\"], color=colors, edgecolor=\"white\")\n",
    "\n",
    "ax.axvline(x=70, color=\"#f39c12\", linestyle=\"--\", linewidth=1.5, label=\"RS 70 threshold\")\n",
    "ax.axvline(x=50, color=\"#95a5a6\", linestyle=\":\",  linewidth=1.0, label=\"Market neutral (50)\")\n",
    "\n",
    "for bar, val in zip(bars, rs_df[\"L_value\"]):\n",
    "    ax.text(bar.get_width() + 0.5, bar.get_y() + bar.get_height() / 2,\n",
    "            f\"{val:.0f}\", va=\"center\", fontsize=10)\n",
    "\n",
    "ax.set_xlim(0, 105)\n",
    "ax.set_xlabel(\"RS Rating (0–99)\", fontsize=11)\n",
    "ax.set_title(\"Relative Strength Ratings\", fontsize=14, fontweight='bold')\n",
    "ax.legend(fontsize=9)\n",
    "plt.tight_layout()\n",
    "plt.savefig(\"canslim_rs_chart.png\", dpi=150, bbox_inches='tight')\n",
    "plt.show()\n",
    "print(\"\\n  Saved → canslim_rs_chart.png\")"
   ],
   "id": "cell-rs-chart"
  },
  {
   "cell_type": "code",
   "execution_count": null,
   "metadata": {},
   "outputs": [],
   "source": [
    "# ─────────────────────────────────────────────────────────────\n",
    "# CELL 7 — Price chart with 50/200-day MA for top pick\n",
    "# ─────────────────────────────────────────────────────────────\n",
    "import yfinance as yf\n",
    "import matplotlib.pyplot as plt\n",
    "import matplotlib.dates as mdates\n",
    "\n",
    "# Use the top-scoring symbol\n",
    "top_symbol = df.iloc[0][\"Symbol\"] if not df.empty else \"AAPL\"\n",
    "print(f\"  Charting: {top_symbol}\")\n",
    "\n",
    "hist = yf.Ticker(top_symbol).history(period=\"1y\")\n",
    "hist[\"MA50\"]  = hist[\"Close\"].rolling(50).mean()\n",
    "hist[\"MA200\"] = hist[\"Close\"].rolling(200).mean()\n",
    "\n",
    "fig, (ax1, ax2) = plt.subplots(2, 1, figsize=(12, 7),\n",
    "                                 gridspec_kw={'height_ratios': [3, 1]},\n",
    "                                 sharex=True)\n",
    "\n",
    "# Price + MAs\n",
    "ax1.plot(hist.index, hist[\"Close\"],  color=\"#2c3e50\", linewidth=1.5, label=\"Close\")\n",
    "ax1.plot(hist.index, hist[\"MA50\"],   color=\"#3498db\", linewidth=1.2, linestyle=\"--\", label=\"50-day MA\")\n",
    "ax1.plot(hist.index, hist[\"MA200\"],  color=\"#e74c3c\", linewidth=1.2, linestyle=\"--\", label=\"200-day MA\")\n",
    "\n",
    "ax1.set_title(f\"{top_symbol} — Price + Moving Averages (1 Year)\", fontsize=14, fontweight='bold')\n",
    "ax1.set_ylabel(\"Price ($)\", fontsize=11)\n",
    "ax1.legend(fontsize=9)\n",
    "ax1.grid(alpha=0.3)\n",
    "\n",
    "# Volume\n",
    "colors_vol = [\"#2ecc71\" if c >= o else \"#e74c3c\"\n",
    "              for c, o in zip(hist[\"Close\"], hist[\"Open\"])]\n",
    "ax2.bar(hist.index, hist[\"Volume\"] / 1e6, color=colors_vol, alpha=0.7)\n",
    "ax2.set_ylabel(\"Vol (M)\", fontsize=10)\n",
    "ax2.grid(alpha=0.3)\n",
    "\n",
    "ax2.xaxis.set_major_formatter(mdates.DateFormatter(\"%b '%y\"))\n",
    "plt.xticks(rotation=30)\n",
    "plt.tight_layout()\n",
    "plt.savefig(f\"canslim_{top_symbol}_chart.png\", dpi=150, bbox_inches='tight')\n",
    "plt.show()\n",
    "print(f\"\\n  Saved → canslim_{top_symbol}_chart.png\")"
   ],
   "id": "cell-price-chart"
  },
  {
   "cell_type": "code",
   "execution_count": null,
   "metadata": {},
   "outputs": [],
   "source": [
    "# ─────────────────────────────────────────────────────────────\n",
    "# CELL 8 — Export results to CSV\n",
    "# ─────────────────────────────────────────────────────────────\n",
    "from datetime import datetime\n",
    "\n",
    "filename = f\"canslim_scan_{datetime.now().strftime('%Y%m%d_%H%M')}.csv\"\n",
    "scanner.export_csv(results, filename)\n",
    "\n",
    "# In Colab: download the file to your machine\n",
    "try:\n",
    "    from google.colab import files\n",
    "    files.download(filename)\n",
    "    print(f'  ✓ Download triggered for {filename}')\n",
    "except ImportError:\n",
    "    print(f'  ✓ Saved locally as {filename}')"
   ],
   "id": "cell-export"
  },
